# BioLit environment — copy to .env and fill in secrets.
# Never commit real keys.

# App
APP_NAME=biolit
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# NCBI E-utilities (required for live PubMed; https://ncbiinsights.ncbi.nlm.nih.gov/2017/11/02/new-api-keys-for-the-e-utilities/)
NCBI_API_KEY=
NCBI_EMAIL=you@example.com
NCBI_TOOL=biolit
NCBI_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# Postgres + pgvector
DATABASE_URL=postgresql+psycopg://biolit:biolit@localhost:5432/biolit

# Redis (cache + arq queue)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# LLM providers (LiteLLM). Set the ones you use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEFAULT_LLM_MODEL=gpt-4o-mini

# Langfuse (self-hosted via docker-compose; optional for Phase 0)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Retrieval defaults
RETRIEVAL_TOP_K=20
RETRIEVAL_CANDIDATE_CAP=500
MEDCPT_DEVICE=cpu
EMBEDDING_DIM=768
